{
  "name": "eevex",
  "private": true,
  "version": "0.0.1",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "corepack pnpm --filter @eevex/web build",
    "build:all": "turbo build",
    "dev": "corepack pnpm --filter @eevex/web dev",
    "dev:all": "turbo dev",
    "start": "corepack pnpm --filter @eevex/web start",
    "start:web": "corepack pnpm --filter @eevex/web start",
    "start:dashboard": "corepack pnpm --filter @eevex/dashboard start",
    "start:checkin": "corepack pnpm --filter @eevex/checkin start",
    "start:kiosk": "corepack pnpm --filter @eevex/kiosk start",
    "start:stand": "corepack pnpm --filter @eevex/stand start",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "db:generate": "turbo db:generate",
    "db:push": "turbo db:push",
    "db:studio": "pnpm --filter @eevex/db studio"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "prettier": "^3.3.3",
    "turbo": "^2.9.6",
    "typescript": "^5.6.3"
  }
}
